# Optional Gemini extraction/chat support
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local artifact locations
TIRELIFE_ARTIFACTS_DIR=artifacts
TIRELIFE_DATA_PATH=artifacts/tyre_rul_cleaned.csv
TIRELIFE_MODEL_DIR=artifacts/trained_models

# Use 0 for the full dataset. Lower values start faster on small demo hosts.
PROFILE_SAMPLE_ROWS=220000
TRAIN_SAMPLE_ROWS=220000

# React build served by FastAPI in production.
FRONTEND_DIST_DIR=dist
